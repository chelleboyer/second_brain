# === Slack ===
# Bot token from Slack app (xoxb-...)
SLACK_BOT_TOKEN=xoxb-your-token-here
# Channel ID to monitor (right-click channel > Copy link > extract ID)
SLACK_CHANNEL_ID=C0123456789
# Also collect bot direct messages (true/false)
SLACK_COLLECT_DMS=true

# === Hugging Face Inference API ===
# API token from https://huggingface.co/settings/tokens
HF_API_TOKEN=hf_your_token_here
# Model for classification + title/summary extraction
HF_CLASSIFICATION_MODEL=mistralai/Mistral-7B-Instruct-v0.3
# Model for embeddings (384-dim output)
HF_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# === Qdrant Cloud ===
# Cluster URL from Qdrant Cloud dashboard
QDRANT_URL=https://your-cluster.qdrant.io
# API key from Qdrant Cloud dashboard
QDRANT_API_KEY=your-qdrant-api-key
# Collection name for brain entry vectors
QDRANT_COLLECTION_NAME=brain_entries

# === App ===
# Logging level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
# SQLite database file path (relative to project root, or absolute)
DB_PATH=second_brain.db
